<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/control_row_bg"
        android:gravity="center_vertical"
        android:paddingLeft="16dp"
        android:paddingRight="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="时"
            android:textColor="@color/text_primary_dark"
            android:textSize="15sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/jj_shape"
                android:gravity="center">

                <ImageView
                    android:id="@+id/Sensor5down"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@mipmap/jian" />
            </LinearLayout>

            <TextView
                android:id="@+id/Sensor6"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="12dp"
                android:layout_marginRight="12dp"
                android:minWidth="28dp"
                android:text="0"
                android:textColor="@color/text_primary_dark"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/jj_shape"
                android:gravity="center">

                <ImageView
                    android:id="@+id/Sensor5add"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@mipmap/jia" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/control_row_bg"
        android:gravity="center_vertical"
        android:paddingLeft="16dp"
        android:paddingRight="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="分"
            android:textColor="@color/text_primary_dark"
            android:textSize="15sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/jj_shape"
                android:gravity="center">

                <ImageView
                    android:id="@+id/Sensor6down"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@mipmap/jian" />
            </LinearLayout>

            <TextView
                android:id="@+id/Sensor7"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="12dp"
                android:layout_marginRight="12dp"
                android:minWidth="28dp"
                android:text="0"
                android:textColor="@color/text_primary_dark"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/jj_shape"
                android:gravity="center">

                <ImageView
                    android:id="@+id/Sensor6add"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@mipmap/jia" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/control_row_bg"
        android:gravity="center_vertical"
        android:paddingLeft="16dp"
        android:paddingRight="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="秒"
            android:textColor="@color/text_primary_dark"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/Sensor8"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="72dp"
            android:text="0"
            android:textColor="@color/text_primary_dark"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/control_row_bg"
        android:gravity="center_vertical"
        android:paddingLeft="16dp"
        android:paddingRight="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="持续时长"
            android:textColor="@color/text_primary_dark"
            android:textSize="15sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/jj_shape"
                android:gravity="center">

                <ImageView
                    android:id="@+id/Sensor7down"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@mipmap/jian" />
            </LinearLayout>

            <TextView
                android:id="@+id/GOTIME"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="12dp"
                android:layout_marginRight="12dp"
                android:minWidth="28dp"
                android:text="0"
                android:textColor="@color/text_primary_dark"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/jj_shape"
                android:gravity="center">

                <ImageView
                    android:id="@+id/Sensor7add"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@mipmap/jia" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</merge>
